{
  "name": "jo0kker/omr",
  "description": "Optical Mark Recognition from PHP (fork PHP 8.1+ de jansenfelipe/omr)",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Jansen Felipe",
      "email": "jansen.felipe@gmail.com"
    }
  ],
  "keywords": [
    "omr",
    "optical mark recognition",
    "survey"
  ],
  "require": {
    "php": "^8.1",
    "ext-imagick": "*",
    "symfony/console": "^5.4 || ^6.0 || ^7.0"
  },
  "bin": ["bin/omr"],
  "require-dev": {
    "phpunit/phpunit": "^9.5"
  },
  "autoload": {
    "psr-4": {
      "JansenFelipe\\OMR\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "JansenFelipe\\OMR\\Tests\\": "tests/"
    }
  },
  "extra": {
    "branch-alias": {
      "dev-master": "2.0-dev"
    }
  },
  "minimum-stability": "stable"
}
